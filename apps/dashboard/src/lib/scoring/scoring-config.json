{
  "$schema": "scoring-config-v1.0.0",
  "version": "1.0.0",
  "created": "2026-03-22",
  "description": "Project Truth 5-Layer Confidence Scoring Configuration. Tested against 315 entities across 10 documents with 99.7% calibration.",

  "documentTypes": {
    "sworn_testimony": { "baseline": 0.95, "ceiling": 0.98, "description": "Sworn testimony under oath, perjury penalty" },
    "court_filing":    { "baseline": 0.88, "ceiling": 0.95, "description": "Filed in court proceeding, Rule 11 signed" },
    "fbi_report":      { "baseline": 0.82, "ceiling": 0.92, "description": "FBI investigation file, FOIA release" },
    "government_filing": { "baseline": 0.78, "ceiling": 0.90, "description": "Official government document" },
    "deposition_reference": { "baseline": 0.75, "ceiling": 0.88, "description": "Deposition-cited facts and references" },
    "complaint":       { "baseline": 0.72, "ceiling": 0.85, "description": "Rule 11 certified advocacy document" },
    "legal_correspondence": { "baseline": 0.70, "ceiling": 0.85, "description": "Attorney correspondence, not sworn" },
    "credible_journalism": { "baseline": 0.65, "ceiling": 0.82, "description": "Published journalism, editorial standards" }
  },

  "subSourceAdjustments": {
    "sworn_affidavit":       0.02,
    "police_reports":        0.01,
    "fbi_302":               0.00,
