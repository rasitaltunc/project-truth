  "calibrationReference": {
    "totalEntities": 315,
    "correctClassifications": 314,
    "calibrationRate": 0.997,
    "documentsUsed": 10,
    "documentTypesUsed": ["sworn_testimony", "court_filing", "fbi_report", "deposition_reference", "complaint", "credible_journalism", "legal_correspondence"]
