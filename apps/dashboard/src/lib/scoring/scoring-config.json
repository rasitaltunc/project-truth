  "newspaperOnlyB3Discount": -0.02,

  "evidenceTypeBoosts": {
    "sworn_testimony":   0.02,
    "police_record":     0.015,
    "fbi_302":           0.015,
    "fbi_report":        0.015,
    "court_record":      0.01,
    "physical_evidence": 0.02,
    "financial_record_subpoenaed": 0.01,
    "financial_record_newspaper":  0.005
  },

  "mentionVolumeBonus": {
    "high": { "threshold": 100, "bonus": 0.01 },
    "medium": { "threshold": 20, "bonus": 0.005 }
  },

  "natoScoreMap": {
    "A1": 0.05, "A2": 0.04, "A3": 0.03,
    "B1": 0.04, "B2": 0.03, "B3": 0.02,
    "C1": 0.03, "C2": 0.02, "C3": 0.01,
    "D1": 0.02, "D2": 0.01, "D3": 0.00,
    "E1": 0.01, "E2": 0.00, "E3": -0.01, "E4": -0.02
  },

  "berkeleyBoosts": {
    "physical_evidence": 0.015,
    "sworn_testimony":   0.015,
    "police_record":     0.01,
    "fbi_302":           0.01,
    "fbi_report":        0.01,
    "financial_record":  0.005,
    "court_record":      0.005,
    "newspaperOnlyDiscount": -0.01,
    "richEvidenceThreshold": 4,
    "richEvidenceBonus":     0.01,
    "multiEvidenceThreshold": 2,
    "multiEvidenceBonus":     0.005
  },

  "achConfig": {
    "swornTypes":    ["sworn_testimony"],
    "physicalTypes": ["police_record", "fbi_302", "physical_evidence", "financial_record"],
    "legalTypes":    ["court_record", "fbi_report"],
    "mediaTypes":    ["credible_journalism"],
    "legalWeight":   0.5,
    "mediaWeight":   0.3,
    "scoreThresholds": [
      { "sources": 5, "score": 0.02 },
      { "sources": 3, "score": 0.015 },
      { "sources": 2, "score": 0.01 },
      { "sources": 1, "score": 0.005 }
    ]
  },

  "transparencyBoosts": {
    "sworn_testimony":   0.005,
    "police_record":     0.005,
    "court_record":      0.005,
    "fbi_302":           0.005,
    "fbi_report":        0.005,
    "physical_evidence": 0.005,
    "financial_record":  0.005
