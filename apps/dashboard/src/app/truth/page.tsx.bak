'use client';

import { useState, useEffect, useRef } from 'react';
import { Canvas } from '@react-three/fiber';
import { CameraControls, Billboard, Text, Html, Line, Float } from '@react-three/drei';
import * as THREE from 'three';
import { AnimatePresence, motion } from 'framer-motion';
import { Loader2 } from 'lucide-react';
import { useStore } from '@/store/useStore';
import EvidenceModal from '@/components/EvidenceModal';

// === AVATAR MOTORU ===
function createAvatarTexture(name: string) {
    const canvas = document.createElement('canvas');
    canvas.width = 512;
    canvas.height = 512;
    const ctx = canvas.getContext('2d');
    if (!ctx) return null;

    ctx.fillStyle = '#111';
    ctx.fillRect(0, 0, 512, 512);
    ctx.lineWidth = 20;
    ctx.strokeStyle = '#333';
    ctx.strokeRect(10, 10, 492, 492);
    ctx.fillStyle = '#666';
    ctx.font = 'bold 200px Courier New';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';

    // Güvenli İsim Kontrolü
    const safeName = name || "UN";
    const initials = safeName.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase();
    ctx.fillText(initials, 256, 256);

    const texture = new THREE.CanvasTexture(canvas);
    texture.colorSpace = THREE.SRGBColorSpace;
    return texture;
}

// === 1. ZIRHLI RESİM MOTORU (V16 Standardı) ===
function SmartImage3D({ label, imgUrl }: { label: string, imgUrl?: string | null }) {
    const [texture, setTexture] = useState<THREE.Texture | null>(null);

    useEffect(() => {
        // 1. Resim yoksa hemen RAM Avatarı üret
        if (!imgUrl) {
            const ramTex = createAvatarTexture(label);
            if (ramTex) setTexture(ramTex);
            return;
        }

        // 2. Resim varsa yükle
        const loader = new THREE.TextureLoader();
        loader.setCrossOrigin('anonymous');
        loader.load(
            imgUrl,
            (tex) => {
                tex.colorSpace = THREE.SRGBColorSpace;
                setTexture(tex);
            },
            undefined,
            () => {
                // Hata olursa fallback
                const ramTex = createAvatarTexture(label);
                if (ramTex) setTexture(ramTex);
            }
        );
    }, [imgUrl, label]);

    // Texture henüz yüklenmediyse de boş durmasın
    const displayTexture = texture || createAvatarTexture(label);

    return (
        <mesh>
            <planeGeometry args={[3, 4]} />
            {/* Işık gerektirmeyen BasicMaterial - Fotoğraflar her zaman net görünür */}
            <meshBasicMaterial map={displayTexture || undefined} side={THREE.DoubleSide} toneMapped={false} />
        </mesh>
    );
}


function SpatialPanel({ node, onClose }: { node: any, onClose: () => void }) {
    return (
        <Html
            position={[3.8, 0, 0]} // Adamın sağında
            transform
            occlude={false}
            distanceFactor={8}
            style={{ pointerEvents: 'auto' }}
        >
            <motion.div
                initial={{ opacity: 0, x: -10, rotateY: -10 }}
                animate={{ opacity: 1, x: 0, rotateY: 0 }}
                exit={{ opacity: 0, x: -10 }}
                transition={{ type: "spring", stiffness: 120, damping: 20 }}
                // TASARIM: Krem rengi kağıt, Siyah Yazı, Kırmızı Damgalar
                className="w-[400px] bg-[#fdfbf7] text-[#1a1a1a] font-mono border-l-[6px] border-[#8b0000] shadow-[0_20px_50px_rgba(0,0,0,0.8)] flex flex-col relative overflow-hidden rounded-sm"
                onClick={(e) => e.stopPropagation()}
            >
                {/* ARKA PLAN DOKUSU */}
                <div className="absolute top-0 right-0 p-4 opacity-[0.08] pointer-events-none">
                    <Fingerprint size={140} color="black" />
                </div>

                {/* DAMGA */}
                <div className="absolute top-6 right-6 border-[3px] border-[#8b0000] text-[#8b0000] px-3 py-1 font-black text-xl opacity-40 -rotate-12 pointer-events-none tracking-widest">
                    TOP SECRET
                </div>

                {/* HEADER */}
                <div className="bg-[#e8e4da] p-3 border-b border-[#d4d0c7] flex justify-between items-center">
                    <div className="flex items-center text-[10px] font-bold text-[#555] tracking-widest">
                        <Database size={12} className="mr-2" />
                        INTELLIGENCE DOSSIER // {node.id.substring(0, 4).toUpperCase()}
                    </div>
                    <button onClick={onClose} className="text-[#888] hover:text-[#8b0000] transition">
                        <X size={20} />
                    </button>
                </div>

                {/* BODY */}
                <div className="p-6">
                    {/* İSİM BAŞLIĞI */}
                    <div className="border-b-4 border-black pb-2 mb-5">
                        <h1 className="text-4xl font-black uppercase tracking-tighter leading-none text-black">
                            {node.label}
                        </h1>
                    </div>

                    {/* BİLGİ KUTUCUKLARI */}
                    <div className="grid grid-cols-2 gap-4 mb-6">
                        <div className="bg-[#f0ece4] p-2 border border-[#dcd8ce]">
                            <span className="block text-[9px] text-[#666] font-bold mb-1 tracking-wider">CURRENT STATUS</span>
                            <span className={`text-xs font-bold px-2 py-0.5 inline-block ${node.is_alive ? 'bg-[#d1fae5] text-[#065f46]' : 'bg-black text-white'}`}>
                                {node.is_alive ? '● ACTIVE' : '† DECEASED'}
                            </span>
                        </div>
                        <div className="bg-[#f0ece4] p-2 border border-[#dcd8ce]">
                            <span className="block text-[9px] text-[#666] font-bold mb-1 tracking-wider">NETWORK ROLE</span>
                            <span className="text-xs font-bold text-black border-b border-black uppercase">{node.type}</span>
                        </div>
                    </div>

                    {/* RISK RAPORU */}
                    <div className="mb-6 relative">
                        <div className="flex justify-between items-end mb-1">
                            <span className="text-[10px] font-bold text-[#8b0000] flex items-center">
                                <ShieldAlert size={12} className="mr-1" /> THREAT ASSESSMENT
                            </span>
                            <span className="text-xl font-black text-[#8b0000]">{node.risk}/100</span>
                        </div>
                        <div className="h-2 w-full bg-[#ddd] rounded-full overflow-hidden border border-[#ccc]">
                            <div className="h-full bg-[#8b0000]" style={{ width: `${node.risk}%` }}></div>
                        </div>
                        <p className="mt-2 text-[10px] leading-relaxed text-[#333] text-justify">
                            Subject flagged for high-level involvement. Cross-referenced data indicates direct financial and logistical support to the central node. Immediate surveillance recommended.
                        </p>
                    </div>

                    {/* ACTION BUTTON */}
                    <button
                        className="w-full py-4 bg-[#1a1a1a] hover:bg-[#8b0000] text-white font-bold text-xs tracking-[0.2em] transition-colors flex items-center justify-center group"
                        onClick={(e) => {
                            e.stopPropagation();
                            alert("ERİŞİM İZNİ KONTROL EDİLİYOR... (Buraya Modal Gelecek)");
                        }}
                    >
                        <FileText size={16} className="mr-2 group-hover:text-white" />
                        ACCESS FULL EVIDENCE
                    </button>
                </div>
            </motion.div>
        </Html>
    );
}

// === 2. DÜĞÜM KARTI ===
function NodeCard({ node, isSelected, onSelect }: { node: any, isSelected: boolean, onSelect: (n: any) => void }) {
    const [hovered, setHover] = useState(false);
    const openArchive = useStore((state) => state.openArchive);
    const isTarget = node.type === 'mastermind';

    useEffect(() => {
        document.body.style.cursor = hovered ? 'pointer' : 'auto';
    }, [hovered]);

    // Cinematic click handler with delay
    const handleClick = (e: any) => {
        e.stopPropagation();
        onSelect(node); // Focus camera first

        // Open evidence modal after cinematic pause
        setTimeout(() => {
            openArchive(node);
        }, 1200);
    };

    return (
        <group position={new THREE.Vector3(...node.pos)}>
            <Float speed={2} rotationIntensity={0} floatIntensity={0.5}>
                <Billboard follow={true} lockX={false} lockY={false} lockZ={false}>
                    <group scale={isSelected ? 1.1 : 1}>

                        {/* TIKLAMA ALANI (PHANTOM HITBOX) */}
                        <mesh
                            position={[0, 0, 0.1]}
                            onClick={handleClick}
                            onPointerOver={() => setHover(true)}
                            onPointerOut={() => setHover(false)}
                        >
                            <planeGeometry args={[3.2, 4.2]} />
                            <meshBasicMaterial transparent opacity={0} />
                        </mesh>

                        {/* RESİM */}
                        <group position={[0, 0, -0.01]}>
                            <SmartImage3D label={node.label} imgUrl={node.img} />
                        </group>

                        {/* ÇERÇEVE */}
                        <mesh position={[0, 0, -0.02]}>
                            <planeGeometry args={[3.2, 4.2]} />
                            <meshBasicMaterial color={isTarget ? '#991b1b' : '#262626'} transparent opacity={1} />
                        </mesh>

                        {/* İSİM (Varsayılan Font - Hata Vermez) */}
                        <Text
                            position={[0, -2.5, 0]}
                            fontSize={0.35}
                            color={isSelected ? "#ef4444" : "#e5e5e5"}
                            anchorX="center"
                            anchorY="middle"
                        >
                            {node.label.toUpperCase()}
                        </Text>

                        {/* ÖLÜ DAMGASI */}
                        {node.is_alive === false && (
                            <Text
                                position={[0, 0, 0.1]}
                                fontSize={0.6}
                                color="#ef4444"
                                anchorX="center"
                                anchorY="middle"
                                rotation={[0, 0, 0.2]}
                            >
                                DECEASED
                            </Text>
                        )}
                    </group>
                </Billboard>
            </Float>
        </group>
    );
}

// === 3. İPLER (SABİT VE SAĞLAM) ===
function SmartString({ start, end }: { start: number[], end: number[] }) {
    return (
        <Line
            points={[start, end]}
            color="#b91c1c"
            lineWidth={3}
            transparent
            opacity={0.4}
        />
    );
}

// === 4. KAMERA YÖNETMENİ (THE DIRECTOR) ===
function CameraDirector({ selectedNode }: { selectedNode: any }) {
    const controlsRef = useRef<CameraControls>(null);

    useEffect(() => {
        if (controlsRef.current) {
            controlsRef.current.setLookAt(0, 0, 40, 0, 0, 0, false);
        }
    }, []);

    useEffect(() => {
        if (!controlsRef.current) return;

        if (selectedNode) {
            // SİNEMATİK ZOOM (V16.1 AYARLARI)
            const targetPos = new THREE.Vector3(...selectedNode.pos);
            const box = new THREE.Box3().setFromCenterAndSize(targetPos, new THREE.Vector3(4, 5, 1));

            // Adam SOLDA, Panel SAĞDA kalsın diye Padding
            controlsRef.current.fitToBox(box, true, {
                paddingTop: 1,
                paddingBottom: 1,
                paddingLeft: 1,
                paddingRight: 5,
            });
        } else {
            // RESET
            controlsRef.current.setLookAt(0, 0, 40, 0, 0, 0, true);
        }
    }, [selectedNode]);

    return (
        <CameraControls
            ref={controlsRef}
            maxDistance={100}
            minDistance={2}
            dollySpeed={0.5}
            smoothTime={0.8}
            makeDefault
        />
    );
}

// === 5. SAHNE ===
function Scene({ nodes, links, selectedNode, onNodeSelect }: any) {
    return (
        <>
            <CameraDirector selectedNode={selectedNode} />

            {/* Işıklar */}
            <ambientLight intensity={1} />
            <pointLight position={[10, 10, 10]} intensity={1} />

            {/* Düğümler */}
            {nodes.map((node: any) => (
                <NodeCard
                    key={node.id}
                    node={node}
                    isSelected={selectedNode && selectedNode.id === node.id}
                    onSelect={(n) => {
                        if (selectedNode && selectedNode.id === n.id) onNodeSelect(null);
                        else onNodeSelect(n);
                    }}
                />
            ))}

            {/* İpler */}
            {links.map((link: any, i: number) => {
                const source = nodes.find((n: any) => n.id === link.source);
                const target = nodes.find((n: any) => n.id === link.target);
                if (!source || !target) return null;
                return <SmartString key={i} start={source.pos} end={target.pos} />;
            })}
        </>
    );
}

// === ANA UYGULAMA ===
export default function Truth3D() {
    const [selectedNode, setSelectedNode] = useState<any>(null);
    const [nodes, setNodes] = useState<any[]>([]);
    const [links, setLinks] = useState<any[]>([]);
    const [loading, setLoading] = useState(true);

    useEffect(() => {
        async function fetchData() {
            try {
                const res = await fetch('/api/truth');
                const data = await res.json();
                setNodes(data.nodes || []);
                setLinks(data.links || []);
            } catch (e) {
                console.error("Veri hatası", e);
            } finally {
                setLoading(false);
            }
        }
        fetchData();
    }, []);

    return (
        <div className="fixed inset-0 w-screen h-screen bg-[#050505] overflow-hidden font-sans">

            {/* EVIDENCE MODAL (Global) */}
            <AnimatePresence>
                <EvidenceModal />
            </AnimatePresence>

            {loading && (
                <div className="absolute inset-0 flex items-center justify-center text-red-600 font-mono gap-2 z-50">
                    <Loader2 className="animate-spin" /> YÜKLENİYOR...
                </div>
            )}

            {/* BOŞLUK TIKLAMASI (RESET) */}
            <Canvas className="z-10" dpr={[1, 2]} onPointerMissed={() => setSelectedNode(null)}>
                <Scene nodes={nodes} links={links} selectedNode={selectedNode} onNodeSelect={setSelectedNode} />
            </Canvas>

            {/* UI BAŞLIK */}
            <div className="absolute top-0 left-0 w-full p-8 z-50 pointer-events-none select-none">
                <h1 className="text-5xl md:text-7xl font-black tracking-tighter text-[#1a1a1a] drop-shadow-[0_1px_0_rgba(255,255,255,0.1)]">
                    PROJECT TRUTH
                </h1>
                <div className="flex items-center space-x-3 mt-2">
                    <div className="h-px w-20 bg-red-900"></div>
                    <div className="flex items-center text-xs text-red-900 font-mono font-bold space-x-2">
                        <span className="tracking-[0.5em]">CLASSIFIED</span>
                        <span className="px-1 bg-red-900 text-white animate-pulse">● LIVE</span>
                    </div>
                </div>
            </div>
        </div>
    );
}
